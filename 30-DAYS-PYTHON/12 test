# T-Shirt Ordering System

def show_menu():
    print("\n--- T-Shirt Menu ---")
    print("1. Basic T-Shirt - $10")
    print("2. Premium T-Shirt - $20")
    print("3. Designer T-Shirt - $30")


def get_price(choice):
    if choice == 1:
        return "Basic T-Shirt", 10
    elif choice == 2:
        return "Premium T-Shirt", 20
    elif choice == 3:
        return "Designer T-Shirt", 30
    else:
        return None, 0


def get_size_price(size):
    if size.upper() == "S":
        return 0
    elif size.upper() == "M":
        return 2
    elif size.upper() == "L":
        return 3
    elif size.upper() == "XL":
        return 5
    else:
        return None


def main():
    orders = []
    total = 0

    print("Welcome to the T-Shirt Ordering System 👕")

    while True:
        show_menu()

        try:
            choice = int(input("Choose a T-shirt (1-3): "))
        except ValueError:
            print("Invalid input. Please enter a number.")
            continue

        name, base_price = get_price(choice)
        if base_price == 0:
            print("Invalid choice.")
            continue

        size = input("Choose size (S, M, L, XL): ")
        size_extra = get_size_price(size)

        if size_extra is None:
            print("Invalid size.")
            continue

        try:
            quantity = int(input("Enter quantity: "))
        except ValueError:
            print("Invalid quantity.")
            continue

        item_total = (base_price + size_extra) * quantity
        total += item_total

        orders.append({
            "name": name,
            "size": size.upper(),
            "quantity": quantity,
            "item_total": item_total
        })

        more = input("Do you want to order more? (y/n): ")
        if more.lower() != "y":
            break

    # Print receipt
    print("\n--- Order Summary ---")
    for order in orders:
        print(f"{order['name']} (Size {order['size']}) x{order['quantity']} = ${order['item_total']}")

    print(f"\nTotal Amount: ${total}")
    print("Thank you for your order!")


if __name__ == "__main__":
    main()

